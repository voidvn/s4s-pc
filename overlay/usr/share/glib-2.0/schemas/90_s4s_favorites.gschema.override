# Default GNOME Shell dash (favorites) for s4s-pc. Compiled into
# gschemas.compiled by chroot-setup.sh (glib-compile-schemas).
# 'vaultwarden.desktop' is our launcher (opens http://localhost:8080).
[org.gnome.shell]
favorite-apps=['vaultwarden.desktop', 'google-chrome.desktop', 'firefox.desktop', 'org.gnome.Nautilus.desktop', 'org.gnome.Terminal.desktop', 'code.desktop', 'org.gnome.Settings.desktop']
