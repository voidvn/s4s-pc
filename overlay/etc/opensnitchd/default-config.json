{
  "Server": { "Address": "unix:///tmp/osui.sock", "LogFile": "/var/log/opensnitchd.log" },
  "DefaultAction": "allow",
  "DefaultDuration": "always",
  "InterceptUnknown": true,
  "ProcMonitorMethod": "ebpf",
  "Firewall": "nftables",
  "Stats": { "MaxEvents": 150, "MaxStats": 25 },
  "Database": {
    "Type": "file",
    "File": "/var/lib/opensnitchd/opensnitch.db",
    "MaxOpenConns": 0
  }
}
